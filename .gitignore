# Finance .gitignore

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.env.local
.env.*.local

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ──────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb_checkpoints/

# ── dbt ──────────────────────────────────────────────────────
dbt/target/
dbt/dbt_packages/
dbt/logs/

# ── Airflow ──────────────────────────────────────────────────
airflow/logs/
airflow/plugins/__pycache__/

# ── MLflow ───────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── Data ─────────────────────────────────────────────────────
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet
data/processed/*.csv
data/processed/*.json
data/processed/*.parquet

# ── Secrets ──────────────────────────────────────────────────
*.pem
*.key
*.crt
secrets/

# ── Poetry (não deve ser lido pelo Streamlit Cloud) ──────────
pyproject.toml
poetry.lock

# ── Claude AI / Configuração interna ─────────────────────────
claude.md
CLAUDE.md
.claude/
skills/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Terraform ────────────────────────────────────────────────
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/.terraform.lock.hcl

# ── mypy ─────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ruff ─────────────────────────────────────────────────────
.ruff_cache/
